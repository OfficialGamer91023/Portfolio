# Backend Environment Variables

# PostgreSQL connection string
# Local: postgresql://localhost:5432/rafay_portfolio
# Render: use the Internal Database URL from your Render PostgreSQL dashboard
DATABASE_URL="postgresql://localhost:5432/rafay_portfolio"

# Server port
PORT=3001

# Allowed CORS origins (comma-separated for multiple origins)
# Example: http://localhost:5173,https://rafay-portfolio.vercel.app
CORS_ORIGIN="http://localhost:5173"
